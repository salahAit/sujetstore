# ==========================
# منصة DzLearn - .gitignore
# ==========================

# Dependencies
node_modules/

# Build outputs
.svelte-kit/
build/
dist/

# Environment files
.env
.env.local
.env.*.local
!.env.example

# SQLite databases (production only - keep in version control for development)
# Uncomment for production:
# data/*.db
data/*.db-wal
data/*.db-shm
data/backups/
data/*_remote.db

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
bun-debug.log*

# Cache
.cache/
.turbo/

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Misc
*.bak
*.tmp
*.temp

# Local debug/utility scripts
scripts/debug_*.ts
scripts/temp_*.ts
scripts/test_*.ts

# Generated Subject Data
static/generated/
static/wasm/
