{
	"name": "sujetstore",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "bun --bun run vite dev",
		"build": "bun --bun run vite build",
		"preview": "bun --bun run vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --plugin prettier-plugin-svelte --plugin prettier-plugin-tailwindcss --write .",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:push:content": "drizzle-kit push --config=drizzle.content.config.ts",
		"db:studio": "drizzle-kit studio",
		"db:studio:content": "drizzle-kit studio --config=drizzle.content.config.ts",
		"seed": "bun run scripts/seed-education.ts",
		"prepare": "svelte-kit sync || echo ''"
	},
	"devDependencies": {
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.561.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/bcryptjs": "^3.0.0",
		"@types/bun": "^1.3.4",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.8",
		"mode-watcher": "^1.1.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.43.8",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.2.2"
	},
	"dependencies": {
		"@fontsource/cairo": "^5.2.7",
		"@tailwindcss/vite": "^4.1.17",
		"bcryptjs": "^3.0.3",
		"drizzle-orm": "^0.45.1",
		"lucide-svelte": "^0.563.0",
		"slugify": "^1.6.6"
	}
}